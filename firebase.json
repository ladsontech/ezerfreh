{
  "firestore": {
    "rules": "firestore.rules"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "hosting": {
    "public": "build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "ezerfresh-f87af",
          "appId": "1:562553165879:android:e29dd9ca5f13ceeccdc7b2",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "ezerfresh-f87af",
          "configurations": {
            "android": "1:562553165879:android:e29dd9ca5f13ceeccdc7b2",
            "ios": "1:562553165879:ios:1b5db6ca9d1e9695cdc7b2",
            "web": "1:562553165879:web:40f7258a3985dafdcdc7b2",
            "windows": "1:562553165879:web:1fb167bab24a2552cdc7b2"
          }
        }
      }
    }
  }
}
